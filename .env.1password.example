# Permaplanner — secret references for `npm run dev` (resolved via `op run --env-file`).
# Generate `.env.1password` from this file (gitignored) with:
#   npm run gen:env:1password -- <vault-name-or-id> <item-title-or-item-id>
#
# Do not wrap op:// lines in quotes; quotes can end up inside VITE_GITHUB_CLIENT_ID and break GitHub.
#
# The generator replaces the `op://…/…/` vault and item segments in the variable lines below.
# https://developer.1password.com/docs/cli/secret-reference-syntax/
#
VITE_GITHUB_CLIENT_ID=op://__VAULT__/__ITEM__/VITE_GITHUB_CLIENT_ID
#
# OAuth app client secret — injected only by the local/production token proxy (server env),
# never bundled into the Vite client.
GITHUB_CLIENT_SECRET=op://__VAULT__/__ITEM__/GITHUB_CLIENT_SECRET
